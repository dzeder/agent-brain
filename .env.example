# Real values go in Doppler — never paste values in this file.
# See AGENT_PRODUCT_CYCLE.md §Secrets & Credentials for the full policy.

# === Models ===
# Specified in: §Model Selection Strategy.
# Pin the full date-stamped model string at adoption (e.g. claude-sonnet-4-6-YYYYMMDD).
# Never hardcode a model string in agent logic — always reference these env vars.
MODEL_CEO=                    # CEO orchestration agent — default claude-sonnet-4-6 (upgrade to claude-opus-4-7 for ambiguous goal parsing)
MODEL_MANAGER=                # Manager agents — default claude-sonnet-4-6
MODEL_WORKER_COMPLEX=         # Complex workers (code, data transforms, multi-step reasoning) — default claude-sonnet-4-6
MODEL_WORKER_SIMPLE=          # High-volume / simple workers (extraction, classification, lookups) — default claude-haiku-4-5
MODEL_EVAL=                   # LLM-as-judge eval + red team — default claude-opus-4-7
DEV_MODEL_OVERRIDE=           # Optional Haiku override for dev iteration on Sonnet/Opus agents (§Environment Management exception)

# === Feature Flags ===
# Specified in: §Environment Management.
# Every significant behavior change ships behind a flag. Flags managed in config, never in prompts.
FEATURE_EXTENDED_THINKING_CEO=        # true|false — extended thinking for CEO goal parsing on ambiguous inputs
FEATURE_EXTENDED_THINKING_MANAGERS=   # true|false — extended thinking for manager coaching analysis when pattern is unclear
FEATURE_PROMPT_CACHING=               # true|false — enable Anthropic prompt caching at the configured breakpoints

# === Runtime ===
# Specified in: §Tooling Stack and §Environment Management.
MANAGED_AGENTS_BETA_HEADER=   # Anthropic Managed Agents beta header value (e.g. managed-agents-2026-04-01)

# === Human Principal ===
# Specified in: §Repo Architecture > Human Principal Role.
# There must always be a named backup — "no backup" is not an acceptable configuration.
HUMAN_PRINCIPAL_PRIMARY=      # Name of the human with final approval authority
HUMAN_PRINCIPAL_BACKUP=       # Name of the backup principal — receives approvals if primary times out
HUMAN_PRINCIPAL_TIMEZONE=     # IANA timezone, e.g. America/New_York
HUMAN_PRINCIPAL_SLACK_ID=     # Slack member ID for approval-request DMs

# === Integrations ===
# AGENT_PRODUCT_CYCLE.md does not enumerate specific integration credential names.
# Add tool-specific credentials here as integrations are wired up.
# Tools referenced in §Tooling Stack:
#   Anthropic API · GitHub · Doppler · Langfuse · Sentry · PostHog · Grafana · Snyk
#   Notion · Linear · Jira · Monday.com · Slack · n8n · Braintrust/Promptfoo
# All values must be sourced from Doppler — never pasted into this file.

# --- Linear ---
# Per /docs/runbooks/linear-setup.md.
# Used by: managers (task queue CRUD), CEO (escalation issue creation),
# autodream (hiring tracking + coaching event linkage).
LINEAR_API_KEY=               # Personal API key from Settings → My Account → API → Personal API keys
LINEAR_WORKSPACE_SLUG=        # Workspace URL slug (e.g., 'ohanafy' from linear.app/ohanafy/...)
LINEAR_BRAIN_OPS_TEAM_KEY=    # Team key for the brain-ops team (e.g., 'BRAIN'). Per-product-repo manager teams added later.
