      "path": "/schemas/agents/message-envelope/v1.0.0.json"
    },
    {
      "schema_id": "health-report",
      "domain": "agents",
      "latest_version": "1.0.0",
      "path": "/schemas/agents/health-report/v1.0.0.json"
    },
    {
      "schema_id": "signed-output",
      "domain": "workers",
      "latest_version": "1.0.0",
      "path": "/schemas/workers/signed-output/v1.0.0.json"
    },
    {
      "schema_id": "reflection",
      "domain": "workers",
      "latest_version": "1.0.0",
      "path": "/schemas/workers/reflection/v1.0.0.json"
    },
    {
      "schema_id": "synthetic-data-generator-input",
      "domain": "skills",
      "latest_version": "1.0.0",
      "path": "/schemas/skills/synthetic-data-generator/input/v1.0.0.json"
    },
    {
      "schema_id": "synthetic-data-generator-output",
      "domain": "skills",
      "latest_version": "1.0.0",
      "path": "/schemas/skills/synthetic-data-generator/output/v1.0.0.json"
    }
  ]
}
